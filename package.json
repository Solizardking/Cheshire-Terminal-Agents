{
  "name": "cheshire-terminal-agents",
  "version": "1.45.0",
  "description": "Cheshire Terminal Agents — dual-chain identity forge (Robinhood Chain EVM + Solana SVM) plus production DeFi/Solana agent catalog, schema, and locales for cheshireterminal.ai/agents",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Cheshire Terminal <operators@cheshireterminal.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/Cheshire-Terminal-Agents.git"
  },
  "homepage": "https://cheshireterminal.ai/agents",
  "bugs": {
    "url": "https://github.com/Solizardking/Cheshire-Terminal-Agents/issues"
  },
  "keywords": [
    "cheshire-terminal",
    "cheshire-terminal-agents",
    "ai-agents",
    "defi",
    "erc-8004",
    "evm",
    "robinhood-chain",
    "solana",
    "svm",
    "metaplex",
    "clawd",
    "mcp",
    "layerzero",
    "zk",
    "omnichain",
    "nullifier",
    "relayer"
  ],
  "bin": {
    "cheshire-terminal-agents": "./src/cli.js",
    "ct-agents": "./src/cli.js",
    "robinhood-agents": "./src/cli.js",
    "zk-omni-relayer": "./scripts/zk-omni-relayer.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./agentCatalog": "./src/agentCatalog.js",
    "./skillPack": "./src/skillPack.js",
    "./packagesCatalog": "./src/packagesCatalog.js",
    "./deployments": "./src/deployments.js",
    "./zkOmni": "./src/zkOmni/index.js",
    "./deployments/mainnet-4663": "./deployments/agent-registries-mainnet-4663.json",
    "./deployments/testnet-46630": "./deployments/agent-registries-testnet-46630.json",
    "./schema/Cheshire_agent_schema.json": "./schema/Cheshire_agent_schema.json",
    "./skills/rh-crypto-agent/pack-index.json": "./skills/rh-crypto-agent/pack-index.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "import:agents": "node scripts/import-agents.mjs",
    "agents:import": "node scripts/import-agents.mjs",
    "agents:validate": "node --test test/agents-catalog.test.js",
    "agents:list": "node -e \"import('./src/agentCatalog.js').then(m=>console.log(m.listCatalogIdentifiers().join('\\n')))\"",
    "skills:list": "node -e \"import('./src/skillPack.js').then(m=>console.log(m.listRhCryptoAgentSkillIds().join('\\n')))\"",
    "skills:inspect": "node -e \"import('./src/skillPack.js').then(m=>console.log(JSON.stringify(m.inspectRhCryptoAgentPack(),null,2)))\"",
    "skills:sync": "node scripts/sync-rh-skill-pack.mjs",
    "packages:list": "node -e \"import('./src/packagesCatalog.js').then(m=>console.log(m.listPackageIds().join('\\n')))\"",
    "packages:inspect": "node -e \"import('./src/packagesCatalog.js').then(m=>console.log(JSON.stringify(m.inspectPackages(),null,2)))\"",
    "validate:agents": "node --test test/agents-catalog.test.js",
    "test": "node --test test/*.test.js deploy/test/*.test.cjs",
    "test:zk-omni": "node --test test/zk-omni.test.js",
    "check": "node --check src/index.js && node --check src/deployments.js && node --check src/agentCatalog.js && node --check src/skillPack.js && node --check src/packagesCatalog.js && node --check src/cli.js && node --check src/zkOmni/codec.js && node --check src/zkOmni/relayer.js && node --check deploy/scripts/deployment-safety.cjs && npm test",
    "setup:solidity": "forge install foundry-rs/forge-std@v1.9.6 --no-git --shallow",
    "test:solidity": "forge test -vv",
    "zk-omni:plan": "node scripts/zk-omni-relayer.mjs plan",
    "zk-omni:oneshot": "node scripts/zk-omni-relayer.mjs oneshot",
    "zk-omni:relayer": "node scripts/zk-omni-relayer.mjs serve",
    "zk-omni:status": "node scripts/zk-omni-relayer.mjs status",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "viem": "^2.38.0"
  },
  "files": [
    "src",
    "agents",
    "locales",
    "schema",
    "packages/clawd-agent-tui/package.json",
    "packages/clawd-agent-tui/README.md",
    "packages/clawd-agent-tui/agent.config.json",
    "packages/clawd-agent-tui/tsconfig.json",
    "packages/clawd-agent-tui/src",
    "packages/headless-agent/package.json",
    "packages/headless-agent/README.md",
    "packages/headless-agent/tsconfig.json",
    "packages/headless-agent/src",
    "packages/layerzero-omnichain/package.json",
    "packages/layerzero-omnichain/README.md",
    "packages/layerzero-omnichain/foundry.toml",
    "packages/layerzero-omnichain/layerzero.config.ts",
    "packages/layerzero-omnichain/contracts",
    "packages/solana-agent-trust/package.json",
    "packages/solana-agent-trust/README.md",
    "packages/solana-agent-trust/Anchor.toml",
    "packages/solana-agent-trust/Cargo.toml",
    "packages/solana-agent-trust/Cargo.lock",
    "packages/solana-agent-trust/programs",
    "scripts/import-agents.mjs",
    "scripts/sync-rh-skill-pack.mjs",
    "scripts/zk-omni-relayer.mjs",
    "contracts",
    "deploy/script",
    "deploy/scripts",
    "deploy/test",
    "deployments",
    "skills",
    "examples",
    "assets",
    "test",
    ".env.example",
    "foundry.toml",
    "remappings.txt",
    "README.md",
    "LICENSE"
  ]
}
