# Required for LLM agent loop
OPENROUTER_API_KEY=sk-or-...

# Optional model override
AGENT_MODEL=anthropic/claude-sonnet-4
AGENT_MAX_STEPS=25
AGENT_MAX_COST=2.0

# ZK Shark / Clawd ZK primitives (optional — tools work offline for pure ops)
ZK_SHARK_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
ZK_SHARK_PROGRAM_ID=CLAWDzk11111111111111111111111111111111111
ZK_SHARK_PHOTON_URL=
ZK_SHARK_API_KEY=
ZK_SHARK_COMMITMENT=confirmed
ZK_SHARK_KEYPAIR=
ZK_SHARK_NETWORK=mainnet

# Path to a local zk-primitives checkout (for docs/manifest tools)
CLAWD_ZK_PRIMITIVES_DIR=/Users/8bit/ClawdBrowser/go-bot/zk-primitives
